# === Database Configuration ===
# MySQL connection string
# Format: mysql+pymysql://username:password@host:port/database
DATABASE_URL=mysql+pymysql://blood_user:your_password@localhost:3306/blood_tracking

# Database setup (for setup_new_database.py)
DB_HOST=localhost
DB_PORT=3308
DB_ROOT_USER=root
DB_ROOT_PASSWORD=your_root_password
NEW_DB_NAME=blood_tracking_v2_1
NEW_DB_USER=blood_user_v2
NEW_DB_PASSWORD=blood_pass_2024

# === Security ===
# Secret key for JWT token signing (change this!)
SECRET_KEY=your-secret-key-change-this-in-production
# JWT algorithm (default: HS256)
ALGORITHM=HS256
# Token expiration in minutes (default: 480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# === API Security ===
# API Key for ESP32 hardware module authentication
API_KEY=your-esp32-api-key-change-this

# === System Settings ===
# Blood bag expiration period in days
BLOOD_BAG_EXPIRATION_DAYS=42
# ESP32 workflow timeout in seconds
ESP32_TIMEOUT=30
# RFID read timeout in seconds
RFID_READ_TIMEOUT=60
# Auto logout minutes of inactivity
AUTO_LOGOUT_MINUTES=30
# Maximum failed login attempts before lockout
MAX_FAILED_LOGIN_ATTEMPTS=5